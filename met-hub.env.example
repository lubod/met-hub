# Redis Configuration
REDIS_URL=redis://redis:6379

# Postgres Configuration
PG_HOST=postgres
PG_PORT=5432
PG_DB=postgres
PG_USER=postgres
PG_PASSWORD=postgres

# Authentication Secrets
# IMPORTANT: Rotate this to a secure, randomly generated 256-bit hex value in production.
# Example command to generate: openssl rand -hex 32
MY_JWT_SECRET=your_rotated_secure_jwt_secret_here
CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
REACT_APP_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# CORS
# Required in production (ENV != "dev"). Set to the origin that serves the frontend.
CORS_ORIGIN=https://www.met-hub.com

# Station Polling
DOM_PASSKEY=

# Environment
ENV=dev
